-- Execute este SQL no Supabase > SQL Editor

-- 1. Tabela de dados do usuário
create table if not exists public.user_data (
  id uuid default gen_random_uuid() primary key,
  user_id uuid references auth.users(id) on delete cascade not null unique,
  base_balance numeric default 0,
  calendar_data jsonb default '{}'::jsonb,
  trades jsonb default '[]'::jsonb,
  updated_at timestamptz default now()
);

-- 2. Habilitar RLS (segurança por linha)
alter table public.user_data enable row level security;

-- 3. Políticas de segurança (cada usuário só acessa seus próprios dados)
create policy "Usuário lê seus dados"
  on public.user_data for select
  using (auth.uid() = user_id);

create policy "Usuário insere seus dados"
  on public.user_data for insert
  with check (auth.uid() = user_id);

create policy "Usuário atualiza seus dados"
  on public.user_data for update
  using (auth.uid() = user_id);

create policy "Usuário deleta seus dados"
  on public.user_data for delete
  using (auth.uid() = user_id);
